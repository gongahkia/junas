digraph aki {
    graph [
        bgcolor="white"
        fontname="Helvetica"
        fontsize=13
        pad=0.6
        ranksep=0.9
        nodesep=0.55
        splines=ortho
        rankdir=TB
    ]
    node [fontname="Helvetica" fontsize=12 style="filled" shape=box penwidth=1.5]
    edge [fontname="Helvetica" fontsize=10 penwidth=1.5 color="#555555"]

    // ── colour palette ─────────────────────────────────────────────────────
    // blue   = capture layer
    // purple = detection layer
    // green  = transform layer
    // orange = output layer
    // grey   = shared / config

    // ── CAPTURE ─────────────────────────────────────────────────────────────
    subgraph cluster_capture {
        label="Capture  (aki-capture)"
        labeljust=l
        style=filled
        color="#BBDEFB"
        fillcolor="#E3F2FD"
        fontname="Helvetica Bold"
        fontsize=12

        macos  [label="ScreenCaptureKit\n(macOS)"    fillcolor="#90CAF9" color="#1565C0"]
        x11    [label="XCB\n(Linux X11)"              fillcolor="#90CAF9" color="#1565C0"]
        wl     [label="PipeWire / ashpd\n(Wayland)"   fillcolor="#90CAF9" color="#1565C0"]
        region [label="Sub-region crop\n(optional)"   fillcolor="#BBDEFB" color="#1565C0"]

        macos -> region [style=dashed]
        x11   -> region [style=dashed]
        wl    -> region [style=dashed]
    }

    // ── CHANNEL 1 ────────────────────────────────────────────────────────────
    raw [label="RawFrame\n(RGBA + dims + timestamp)\nchannel cap=3"
         shape=parallelogram fillcolor="#F5F5F5" color="#757575" fontsize=11]

    region -> raw

    // ── DETECTION ────────────────────────────────────────────────────────────
    subgraph cluster_detect {
        label="Detection  (aki-detect)"
        labeljust=l
        style=filled
        color="#CE93D8"
        fillcolor="#F3E5F5"
        fontname="Helvetica Bold"
        fontsize=12

        diff   [label="FrameDiff\n(pixel-threshold dirty-cell)"  fillcolor="#E1BEE7" color="#6A1B9A"]
        grid   [label="IncrementalOCR\n8×6 grid  (adaptive 2×2–8×6)"  fillcolor="#E1BEE7" color="#6A1B9A"]
        tess   [label="Tesseract OCR\n(leptess, PSM 6, conf≥40)"      fillcolor="#CE93D8" color="#6A1B9A"]
        scan   [label="Pattern Scanner\n(regex registry + whitelist)"  fillcolor="#E1BEE7" color="#6A1B9A"]
        expand [label="Region Expand + Merge\n(10% padding + end-of-line)"  fillcolor="#E1BEE7" color="#6A1B9A"]

        diff -> grid [label="dirty cells"]
        grid -> tess [label="cell crop"]
        tess -> scan [label="TextRegions"]
        scan -> expand
    }

    raw -> diff
    raw -> grid [style=invis] // rank alignment

    // ── CHANNEL 2 ────────────────────────────────────────────────────────────
    detected [label="DetectedRegions\n(RawFrame + matched bboxes)\nchannel cap=3"
              shape=parallelogram fillcolor="#F5F5F5" color="#757575" fontsize=11]

    expand -> detected

    // ── TRANSFORM ────────────────────────────────────────────────────────────
    subgraph cluster_transform {
        label="Transform  (aki-transform)"
        labeljust=l
        style=filled
        color="#A5D6A7"
        fillcolor="#E8F5E9"
        fontname="Helvetica Bold"
        fontsize=12

        xfade [label="Crossfade  (10-frame pixel-blend\non mode switch)"  fillcolor="#C8E6C9" color="#1B5E20"]

        subgraph cluster_modes {
            label="Transform Modes"
            style=filled fillcolor="#F1F8E9" color="#558B2F"
            fontsize=11
            blur     [label="Blur\n(Gaussian σ=15, O(n) separable)" fillcolor="#DCEDC8" color="#33691E"]
            pixelate [label="Pixelate\n(block-avg, 2px–dim/8)"       fillcolor="#DCEDC8" color="#33691E"]
            cartoon  [label="Cartoon\n(bilateral + Sobel + k-means)" fillcolor="#DCEDC8" color="#33691E"]
            ascii    [label="ASCII\n(luminance→ramp, 8×16 cells)"    fillcolor="#DCEDC8" color="#33691E"]
            neural   [label="Neural\n(ONNX Runtime, CUDA/CoreML/CPU)" fillcolor="#DCEDC8" color="#33691E"]
        }

        xfade -> blur     [style=dashed]
        xfade -> pixelate [style=dashed]
        xfade -> cartoon  [style=dashed]
        xfade -> ascii    [style=dashed]
        xfade -> neural   [style=dashed]
    }

    detected -> xfade

    // ── CHANNEL 3 ────────────────────────────────────────────────────────────
    transformed [label="TransformedFrame\n(RGBA + dims + timestamp)\nchannel cap=3"
                 shape=parallelogram fillcolor="#F5F5F5" color="#757575" fontsize=11]

    blur     -> transformed [style=invis]
    pixelate -> transformed [style=invis]
    cartoon  -> transformed [style=invis]
    ascii    -> transformed [style=invis]
    neural   -> transformed
    xfade    -> transformed [style=invis]
    cartoon  -> transformed [style=invis]

    // make transformed appear after transform cluster
    { rank=same; blur pixelate cartoon ascii neural }

    // ── OUTPUT ───────────────────────────────────────────────────────────────
    subgraph cluster_output {
        label="Output  (aki-output)"
        labeljust=l
        style=filled
        color="#FFCC80"
        fillcolor="#FFF3E0"
        fontname="Helvetica Bold"
        fontsize=12

        autodetect [label="Sink Autodetect"           fillcolor="#FFE0B2" color="#E65100"]
        v4l2       [label="v4l2loopback\n(Linux)"      fillcolor="#FFCC80" color="#E65100"]
        coremedia  [label="CoreMediaIO DAL\n(macOS)"   fillcolor="#FFCC80" color="#E65100"]
        mjpeg      [label="HTTP MJPEG\n(:9876, fallback)" fillcolor="#FFCC80" color="#E65100"]
        obs        [label="OBS WebSocket v5\n→ Browser Source" fillcolor="#FFE0B2" color="#E65100"]
        twitch     [label="Twitch RTMP\n(planned)"     fillcolor="#FFF9C4" color="#F9A825" style="filled,dashed"]

        autodetect -> v4l2      [style=dashed]
        autodetect -> coremedia [style=dashed]
        autodetect -> mjpeg     [style=dashed]
        autodetect -> obs       [style=dashed]
        autodetect -> twitch    [style=dashed]
    }

    transformed -> autodetect

    // ── CONFIG ───────────────────────────────────────────────────────────────
    cfg [label="~/.config/ascii-privacy/config.toml\n[capture]  [detection]  [transform]  [output]  [profiles.*]"
         shape=note fillcolor="#ECEFF1" color="#546E7A" fontsize=11]

    cfg -> grid      [style=dotted color="#90A4AE" label="grid_cells\nmin_confidence"]
    cfg -> xfade     [style=dotted color="#90A4AE" label="mode\nintensity"]
    cfg -> autodetect [style=dotted color="#90A4AE" label="sink\nhttp_port"]
    cfg -> region    [style=dotted color="#90A4AE" label="fps\ncrop region"]
}
