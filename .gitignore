# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local
!.env.example
!backend/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# next.js frontend
frontend/node_modules/
frontend/.next/

# vendor datasets (downloaded via make download-data)
vendor-data/

# reference PDFs (SAL/SLR style guides etc.) — copyrighted; contributors
# download themselves per docs/references/README.md
docs/references/*.pdf

# synthetic benchmark candidates require explicit human review before promotion
backend/benchmark/datasets/*_candidates/*
!backend/benchmark/datasets/*_candidates/.gitkeep

CLAUDE.md
AGENTS.md
.claude
