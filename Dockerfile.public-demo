FROM python:3.12-slim AS runtime

ENV PYTHONUNBUFFERED=1 \
    UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    PATH="/app/.venv/bin:${PATH}" \
    JUNAS_PUBLIC_DEMO_ENABLED=1 \
    JUNAS_REVIEW_PERSIST=0 \
    PIPELINE_LAYERS="" \
    JUNAS_PUBLIC_EVIDENCE_ENABLED=0 \
    JUNAS_PUBLIC_EVIDENCE_PROVIDER=none \
    JUNAS_LLM_ENABLED=0 \
    JUNAS_LLM_PROVIDER=none \
    JUNAS_LLM_HELPERS_ENABLED=0 \
    JUNAS_LLM_DEFINED_TERMS_ENABLED=0 \
    JUNAS_LLM_COVERAGE_AUDIT_ENABLED=0 \
    JUNAS_IMAGE_SCAN_PROVIDER=none \
    JUNAS_TENANCY_ENABLED=0

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/* \
    && pip install --no-cache-dir "uv==0.9.21"

COPY pyproject.toml uv.lock README.md ./
COPY config.toml ./
COPY src ./src

RUN uv sync --frozen --no-dev \
    && uv run python -m spacy download en_core_web_sm \
    && uv cache clean

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD curl -fsS "http://127.0.0.1:${PORT:-8000}/ready" >/dev/null || exit 1

CMD ["sh", "-c", "uv run uvicorn junas.backend.main:app --host 0.0.0.0 --port ${PORT:-8000}"]
