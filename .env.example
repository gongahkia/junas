# base64 Fernet key, generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
KT_CRED_KEY=replace-with-fernet-key

KT_DB_PATH=./data/kt.db
KT_LOG_LEVEL=info
KT_RL_BACKEND=in_memory
KT_RL_REDIS_URL=
KT_RL_REDIS_PREFIX=kt:rl
KT_RL_REDIS_TTL_SECONDS=300
KT_HOST=0.0.0.0
KT_PORT=8000

# kilter (post-2026-03 keycloak realm). client_id is not yet public; leave
# unset until the mobile-app client_id is sniffed/published. Hosts can also
# pass it in the credentials payload.
KT_KILTER_CLIENT_ID=
