# Junas runtime
JUNAS_HOST=127.0.0.1
JUNAS_PORT=8000
JUNAS_MAX_REQUEST_BYTES=10485760
JUNAS_PUBLIC_EVIDENCE_ENABLED=0
JUNAS_PUBLIC_EVIDENCE_PROVIDER=none
JUNAS_PUBLIC_EVIDENCE_ENDPOINT=
JUNAS_PUBLIC_EVIDENCE_MAX_RESULTS=5
JUNAS_PUBLIC_EVIDENCE_TIMEOUT_SECONDS=8
JUNAS_LLM_ENABLED=0
JUNAS_LLM_PROVIDER=none
JUNAS_LLM_BASE_URL=http://127.0.0.1:8001/v1
JUNAS_LLM_INPUT_MODE=structured_tokens
JUNAS_LLM_MODEL=gpt-oss-20b
JUNAS_LLM_TIMEOUT_SECONDS=20
JUNAS_LLM_ALLOW_REMOTE_BASE_URL=0
JUNAS_LLM_ALLOW_REMOTE_RAW_TEXT=0
JUNAS_LLM_TENANT_OPT_IN_OPENAI=0
JUNAS_LLM_API_KEY=

# Accuracy-first managed deployment overlay:
# - use docker-compose.managed-llm.yml
# - set JUNAS_LLM_TENANT_OPT_IN_OPENAI=1 only for opted-in tenants
# - keep JUNAS_LLM_INPUT_MODE=structured_tokens unless raw text transfer is contracted

# Build-time synthetic fixture generation only. Do not use with customer text.
OPENAI_API_KEY=

# Public-evidence providers. Runtime use requires JUNAS_PUBLIC_EVIDENCE_ENABLED=1
# and sanitized PrivacyGuard-approved queries.
EXA_API_KEY=
TINYFISH_API_KEY=
SERPER_API_KEY=
SERPAPI_KEY_PRIMARY=
SERPAPI_KEY_BACKUP=

# Legacy generic search key. Not consumed by the current Junas runtime.
SEARCH_API_KEY=

# Azure/OpenAI-compatible LLM endpoints available to map into JUNAS_LLM_*.
# Keep disabled unless a tenant has opted in.
AZURE_ENDPOINT=https://chatbotapi1.openai.azure.com/

GPT5_PRO_ENDPOINT=https://chatgpt4vision-ga.cognitiveservices.azure.com/
GPT5_PRO_DEPLOYMENT=gpt-5-2
GPT5_PRO_API_KEY=
GPT5_PRO_API_VERSION=2025-03-01-preview

GPT5_MINI_ENDPOINT=https://chatgpt4vision-ga.cognitiveservices.azure.com/
GPT5_MINI_DEPLOYMENT=gpt-5-2
GPT5_MINI_API_KEY=
GPT5_MINI_API_VERSION=2024-12-01-preview

# Image/speech providers are future OCR/media surfaces, not active text-runtime deps.
GPT4O_IMG_API_BASE=https://luke-ma2mv9fp-uaenorth.cognitiveservices.azure.com/openai/deployments/dxc-gpt-image-1/images/generations?api-version=2025-04-01-preview
GPT4O_IMG_API_VERSION=2025-04-01-preview
GPT4O_IMG_DEPLOYMENT=gpt-image-1
GPT4O_IMG_API_KEY=

AZURE_SPEECH_API_KEY=
AZURE_SPEECH_REGION=eastus
