# Public hostname served by the TLS edge proxy.
KILTER_TOGETHER_PUBLIC_HOST=climb.example.com
KILTER_TOGETHER_ACME_EMAIL=ops@example.com

# Required for signed room cookies and encrypted provider credentials at rest.
KILTER_TOGETHER_APP_SECRET=replace-with-openssl-rand-hex-32
KILTER_TOGETHER_ENCRYPTION_KEY=replace-with-openssl-rand-base64-32
KILTER_TOGETHER_PREVIOUS_ENCRYPTION_KEY=

# Keep this aligned to the public HTTPS origin.
KILTER_TOGETHER_ALLOWED_ORIGINS=https://climb.example.com
KILTER_TOGETHER_SECURE_COOKIES=true

# Optional Kilter bootstrap account.
KILTER_TOGETHER_KILTER_USERNAME=
KILTER_TOGETHER_KILTER_PASSWORD=

# Operator and observability wiring.
KILTER_TOGETHER_OPERATOR_TOKEN=replace-with-an-operator-token
KILTER_TOGETHER_OTEL_EXPORTER_OTLP_ENDPOINT=
KILTER_TOGETHER_OTEL_EXPORTER_OTLP_INSECURE=false
KILTER_TOGETHER_OTEL_SERVICE_NAME=kilter-together-api
KILTER_TOGETHER_SENTRY_DSN=
KILTER_TOGETHER_SENTRY_ENVIRONMENT=production
KILTER_TOGETHER_SENTRY_RELEASE=

