# Required for signed room cookies.
KILTER_TOGETHER_APP_SECRET=replace-with-openssl-rand-hex-32

# Required for encrypting stored provider credentials. Must decode to 32 bytes.
KILTER_TOGETHER_ENCRYPTION_KEY=replace-with-openssl-rand-base64-32
KILTER_TOGETHER_PREVIOUS_ENCRYPTION_KEY=

# Same-origin deployments can leave this blank. Set it when the API must answer browser
# requests from a different origin.
KILTER_TOGETHER_ALLOWED_ORIGINS=

# Set to false only for local HTTP smoke testing.
KILTER_TOGETHER_SECURE_COOKIES=true

# Optional: provide Kilter credentials only when you want the shared-data sync.
KILTER_TOGETHER_KILTER_USERNAME=
KILTER_TOGETHER_KILTER_PASSWORD=

# Optional frontend build-time overrides.
VITE_APP_BASE_PATH=/
VITE_API_BASE_URL=/api
