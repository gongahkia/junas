KILTER_TOGETHER_DATA_DIR=./data
# KILTER_TOGETHER_DB_PATH=./data/kilter.db
# KILTER_TOGETHER_APP_DB_PATH=./data/app.db
# KILTER_TOGETHER_IMAGE_DIR=./data/images
# KILTER_TOGETHER_KILTER_USERNAME=
# KILTER_TOGETHER_KILTER_PASSWORD=
# KILTER_TOGETHER_APP_SECRET=
# KILTER_TOGETHER_ENCRYPTION_KEY=
# KILTER_TOGETHER_PORT=8082
# PORT=8082  # used by hosted platforms like Railway when KILTER_TOGETHER_PORT is unset
# KILTER_TOGETHER_SECURE_COOKIES=true  # set to false for local HTTP dev
# KILTER_TOGETHER_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
# KILTER_TOGETHER_PREVIOUS_ENCRYPTION_KEY=  # set old key here during key rotation
# KILTER_TOGETHER_STORAGE_WARN_PERCENT=80
# KILTER_TOGETHER_STORAGE_CRITICAL_PERCENT=90
# KILTER_TOGETHER_AUTO_BOOTSTRAP_IF_MISSING=false  # container entrypoint only; useful on Railway
# KILTER_TOGETHER_OPERATOR_TOKEN=
# KILTER_TOGETHER_OTEL_EXPORTER_OTLP_ENDPOINT=
# KILTER_TOGETHER_OTEL_EXPORTER_OTLP_INSECURE=false
# KILTER_TOGETHER_OTEL_SERVICE_NAME=kilter-together-api
# KILTER_TOGETHER_SENTRY_DSN=
# KILTER_TOGETHER_SENTRY_ENVIRONMENT=development
# KILTER_TOGETHER_SENTRY_RELEASE=
