package providers

// Provider scaffold — rename to <name>.go and implement each method.
// Register in register.go: MustRegister(NewExampleProvider())

import (
	"context"
	"fmt"
	"net/http"
	"time"
)

type ExampleProvider struct {
	httpClient *http.Client
}

func NewExampleProvider() *ExampleProvider {
	return &ExampleProvider{
		httpClient: &http.Client{Timeout: 15 * time.Second},
	}
}

// ID returns the unique provider identifier. Must match a ProviderID const in types.go.
func (p *ExampleProvider) ID() ProviderID {
	return "example"
}

