{
  "info": {
    "summary": "API-first PII anonymization and MNPI review service.",
    "title": "Kaypoh Document Safety API",
    "version": "0.1.0"
  },
  "paths": {
    "/anonymize": {
      "post": {
        "request_body_ref": "#/components/schemas/AnonymizeRequest",
        "response_ref": "#/components/schemas/AnonymizeResponse",
        "summary": "Anonymize a document irreversibly",
        "tags": [
          "Anonymization"
        ]
      }
    },
    "/cite-public-source": {
      "post": {
        "request_body_ref": "#/components/schemas/CitePublicSourceRequest",
        "response_ref": "#/components/schemas/CitePublicSourceResponse",
        "summary": "Cite audit-grade public evidence",
        "tags": [
          "Anonymization"
        ]
      }
    },
    "/classify": {
      "post": {
        "request_body_ref": "#/components/schemas/ClassifyRequest",
        "response_ref": "#/components/schemas/ClassifyResponse",
        "summary": "Classify one document",
        "tags": [
          "Classification"
        ]
      }
    },
    "/classify/batch": {
      "post": {
        "request_body_ref": "#/components/schemas/BatchClassifyRequest",
        "response_ref": "#/components/schemas/BatchClassifyResponse",
        "summary": "Classify multiple documents",
        "tags": [
          "Classification"
        ]
      }
    },
    "/diagnostics": {
      "get": {
        "response_ref": "#/components/schemas/DiagnosticsResponse",
        "summary": "Get runtime diagnostics",
        "tags": [
          "Runtime"
        ]
      }
    },
    "/documents/scrub": {
      "post": {
        "request_body_ref": "#/components/schemas/DocumentScrubRequest",
        "response_ref": "#/components/schemas/DocumentScrubResponse",
        "summary": "Scrub document metadata",
        "tags": [
          "Documents"
        ]
      }
    },
    "/health": {
      "get": {
        "response_ref": "#/components/schemas/HealthResponse",
        "summary": "Get runtime health",
        "tags": [
          "Runtime"
        ]
      }
    },
    "/hold-until-public": {
      "post": {
        "request_body_ref": "#/components/schemas/HoldUntilPublicRequest",
        "response_ref": "#/components/schemas/HoldUntilPublicResponse",
        "summary": "Hold high-risk MNPI until public",
        "tags": [
          "Anonymization"
        ]
      }
    },
    "/metrics": {
      "get": {
        "response_ref": null,
        "summary": "Get Prometheus metrics",
        "tags": [
          "Runtime"
        ]
      }
    },
    "/pseudonymize": {
      "post": {
        "request_body_ref": "#/components/schemas/PseudonymizeRequest",
        "response_ref": "#/components/schemas/PseudonymizeResponse",
        "summary": "Pseudonymize a document before sending",
        "tags": [
          "Anonymization"
        ]
      }
    },
    "/ready": {
      "get": {
        "response_ref": "#/components/schemas/ReadyResponse",
        "summary": "Get backend readiness",
        "tags": [
          "Runtime"
        ]
      }
    },
    "/redact": {
      "post": {
        "request_body_ref": "#/components/schemas/RedactRequest",
        "response_ref": "#/components/schemas/RedactResponse",
        "summary": "Redact a document with opaque markers",
        "tags": [
          "Anonymization"
        ]
      }
    },
    "/redact-pii": {
      "post": {
        "request_body_ref": "#/components/schemas/RedactPiiRequest",
        "response_ref": "#/components/schemas/RedactPiiResponse",
        "summary": "Redact PII only",
        "tags": [
          "Anonymization"
        ]
      }
    },
    "/reidentify": {
      "post": {
        "request_body_ref": "#/components/schemas/ReidentifyRequest",
        "response_ref": "#/components/schemas/ReidentifyResponse",
        "summary": "Reidentify previously anonymized text",
        "tags": [
          "Anonymization"
        ]
      }
    },
    "/request-approval": {
      "post": {
        "request_body_ref": "#/components/schemas/RequestApprovalRequest",
        "response_ref": "#/components/schemas/RequestApprovalResponse",
        "summary": "Request reviewer approval",
        "tags": [
          "Anonymization"
        ]
      }
    },
    "/review": {
      "post": {
        "request_body_ref": "#/components/schemas/ReviewRequest",
        "response_ref": "#/components/schemas/ReviewResponse",
        "summary": "Review a document before sending",
        "tags": [
          "Anonymization"
        ]
      }
    },
    "/review/{review_id}": {
      "get": {
        "response_ref": "#/components/schemas/ReviewSessionStateResponse",
        "summary": "Inspect review session state",
        "tags": [
          "Anonymization"
        ]
      }
    },
    "/review/{review_id}/decision": {
      "post": {
        "request_body_ref": "#/components/schemas/ReviewDecisionRequest",
        "response_ref": "#/components/schemas/ReviewDecisionResponse",
        "summary": "Record a per-finding decision",
        "tags": [
          "Anonymization"
        ]
      }
    },
    "/safe-rewrite": {
      "post": {
        "request_body_ref": "#/components/schemas/SafeRewriteRequest",
        "response_ref": "#/components/schemas/SafeRewriteResponse",
        "summary": "Safely rewrite a document deterministically",
        "tags": [
          "Anonymization"
        ]
      }
    }
  },
