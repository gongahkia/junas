{
  "info": {
    "title": "Kaypoh Document Safety API",
    "version": "0.1.0",
    "summary": "API-first PII anonymization and MNPI review service."
  },
  "tags": [
    "Runtime",
    "Classification",
    "Anonymization",
    "Documents"
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Get runtime health",
        "tags": [
          "Runtime"
        ],
        "response_ref": "#/components/schemas/HealthResponse"
      }
    },
    "/ready": {
      "get": {
        "summary": "Get backend readiness",
        "tags": [
          "Runtime"
        ],
        "response_ref": "#/components/schemas/ReadyResponse"
      }
    },
    "/diagnostics": {
      "get": {
        "summary": "Get runtime diagnostics",
        "tags": [
          "Runtime"
        ],
        "response_ref": "#/components/schemas/DiagnosticsResponse"
      }
    },
    "/metrics": {
      "get": {
        "summary": "Get Prometheus metrics",
        "tags": [
          "Runtime"
        ],
        "response_ref": null
      }
    },
    "/classify": {
      "post": {
        "summary": "Classify one document",
        "tags": [
          "Classification"
        ],
        "request_body_ref": "#/components/schemas/ClassifyRequest",
        "response_ref": "#/components/schemas/ClassifyResponse"
      }
    },
    "/classify/batch": {
      "post": {
        "summary": "Classify multiple documents",
        "tags": [
          "Classification"
        ],
        "request_body_ref": "#/components/schemas/BatchClassifyRequest",
        "response_ref": "#/components/schemas/BatchClassifyResponse"
      }
    },
    "/review": {
      "post": {
        "summary": "Review a document before sending",
        "tags": [
          "Anonymization"
        ],
        "request_body_ref": "#/components/schemas/ReviewRequest",
        "response_ref": "#/components/schemas/ReviewResponse"
      }
    },
    "/anonymize": {
      "post": {
        "summary": "Anonymize a document before sending",
        "tags": [
          "Anonymization"
        ],
        "request_body_ref": "#/components/schemas/AnonymizeRequest",
        "response_ref": "#/components/schemas/AnonymizeResponse"
      }
    },
    "/documents/scrub": {
      "post": {
        "summary": "Scrub document metadata",
        "tags": [
          "Documents"
        ],
        "request_body_ref": "#/components/schemas/DocumentScrubRequest",
        "response_ref": "#/components/schemas/DocumentScrubResponse"
      }
    },
    "/reidentify": {
      "post": {
        "summary": "Reidentify previously anonymized text",
        "tags": [
          "Anonymization"
        ],
        "request_body_ref": "#/components/schemas/ReidentifyRequest",
        "response_ref": "#/components/schemas/ReidentifyResponse"
      }
    },
    "/review/{review_id}/decision": {
      "post": {
        "summary": "Record a per-finding decision",
        "tags": [
          "Anonymization"
        ],
        "request_body_ref": "#/components/schemas/ReviewDecisionRequest",
        "response_ref": "#/components/schemas/ReviewDecisionResponse"
      }
    },
    "/review/{review_id}": {
      "get": {
        "summary": "Inspect review session state",
        "tags": [
          "Anonymization"
        ],
        "response_ref": "#/components/schemas/ReviewSessionStateResponse"
      }
    }
  },
  "schemas": {
    "ClassifyRequest": {
      "required": [
        "text"
      ],
      "properties": {
        "text": {
          "type": "string",
          "maxLength": 100000
        },
        "entity_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "debug": {
          "type": "boolean"
        },
        "include_offending_spans": {
          "type": "boolean"
        }
      }
    },
    "BatchClassifyRequest": {
      "required": [
        "items"
      ],
      "properties": {
        "items": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "itemsRef": "#/components/schemas/ClassifyRequest"
        }
      }
    },
    "OffendingSpanResponse": {
      "required": [
        "id",
        "layer",
        "rule",
        "severity",
        "matched_text",
        "start_char",
        "end_char",
        "start_line",
        "start_column",
        "end_line",
        "end_column",
        "is_exact",
        "char_length",
        "line_span"
      ],
      "properties": [
        "id",
        "layer",
        "rule",
        "severity",
        "matched_text",
        "detail",
        "start_char",
        "end_char",
        "start_line",
        "start_column",
        "end_line",
        "end_column",
        "is_exact",
        "char_length",
        "line_span",
        "context_before",
        "context_after",
        "score",
        "score_type",
        "window_index",
        "window_count",
        "window_token_count",
        "window_stride",
        "window_max_seq_len"
      ]
    },
    "ObservabilityResponse": {
      "properties": [
        "degraded",
        "cache_status",
        "active_pipeline",
        "executed_layers",
        "skipped_layers",
        "layer_errors"
      ]
    },
    "MosaicResponse": {
      "required": [
        "entity_id",
        "escalated",
        "recent_event_count",
        "unique_fragment_count",
        "window_hours",
        "threshold"
      ],
      "properties": [
        "entity_id",
        "escalated",
        "recent_event_count",
        "unique_fragment_count",
        "window_hours",
        "threshold",
        "escalation_reason",
        "matched_event_ids"
      ]
    },
    "ReidentifyRequest": {
      "required": [
        "anonymized_text"
      ],
      "properties": [
        "anonymized_text",
        "mapping",
        "document_hash"
      ]
    },
    "ReidentifyResponse": {
      "properties": [
        "request_id",
        "text",
        "replacement_count",
        "timings_ms"
      ]
    },
    "DocumentScrubRequest": {
      "required": [
        "document_base64"
      ],
      "properties": [
        "document_base64",
        "document_filename",
        "document_mime_type"
      ]
    },
    "DocumentScrubResponse": {
      "properties": [
        "request_id",
        "document_base64",
        "document_filename",
        "document_mime_type",
        "scrubbed",
        "actions",
        "metadata_findings",
        "remaining_warnings"
      ]
    },
    "ReviewDecisionRequest": {
      "required": [
        "finding_id",
        "action"
      ],
      "properties": [
        "finding_id",
        "action",
        "replacement_text",
        "rationale",
        "reviewer_id"
      ]
    },
    "ReviewDecisionResponse": {
      "properties": [
        "review_id",
        "finding_id",
        "action",
        "reviewer_id",
        "reviewer_identity_source",
        "seq",
        "ts",
        "hmac"
      ]
    },
    "ReviewSessionStateResponse": {
      "properties": [
        "review_id",
        "text_hash",
        "document_type",
        "source_jurisdiction",
        "destination_jurisdiction",
        "findings",
        "decisions_recorded",
        "audit_exports"
      ]
    },
    "ReviewSessionFindingState": {
      "required": [
        "id",
        "category",
        "rule",
        "severity",
        "matched_text",
        "start_char",
        "end_char"
      ],
      "properties": [
        "id",
        "category",
        "rule",
        "severity",
        "matched_text",
        "start_char",
        "end_char",
        "source",
        "image_locator",
        "image_ocr_confidence",
        "image_ocr_regions",
        "decision",
        "decision_seq",
        "decision_ts",
        "decision_reviewer_id",
        "decision_reviewer_identity_source"
      ]
    },
    "AnonymizeResponse": {
      "properties": [
        "request_id",
        "overall_risk",
        "classification",
        "document_score",
        "pii_score",
        "mnpi_score",
        "source_jurisdiction",
        "destination_jurisdiction",
        "jurisdictions_applied",
        "jurisdiction_policy",
        "document_type",
        "review_profile",
        "document",
        "findings",
        "suggestions",
        "public_evidence",
        "llm_adjudication",
        "privacy_ledger",
        "coverage_warnings",
        "degraded_modes",
        "timings_ms",
        "anonymized_text",
        "document_hash",
        "mapping_persisted",
        "mapping",
        "replacements",
        "redacted_images",
        "redacted_document"
      ]
    },
    "ReviewResponse": {
      "properties": [
        "request_id",
        "overall_risk",
        "classification",
        "document_score",
        "pii_score",
        "mnpi_score",
        "source_jurisdiction",
        "destination_jurisdiction",
        "jurisdictions_applied",
        "jurisdiction_policy",
        "document_type",
        "review_profile",
        "document",
        "findings",
        "suggestions",
        "public_evidence",
        "llm_adjudication",
        "privacy_ledger",
        "coverage_warnings",
        "degraded_modes",
        "timings_ms"
      ]
    }
  }
}
